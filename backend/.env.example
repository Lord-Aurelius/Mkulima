NODE_ENV=production
PORT=4000

# Comma-separated allowed frontend origins for CORS.
# Example:
# APP_ORIGIN=https://mkulima.vercel.app,https://www.mkulima.app
APP_ORIGIN=https://your-frontend-domain.com

# Public base URL for files served by the backend in development/local-storage mode.
# In production this should be your live API origin.
PUBLIC_ASSET_BASE_URL=https://your-backend-domain.com

# Public frontend URL used when generating crop and livestock QR links.
# In production this should be your live app origin.
PUBLIC_APP_URL=https://your-frontend-domain.com

JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=8h

# Neon/Postgres connection string
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# S3-compatible object storage
S3_REGION=us-east-1
S3_BUCKET=mkulima-assets
S3_ENDPOINT=https://your-s3-endpoint.com
S3_ACCESS_KEY=replace-me
S3_SECRET_KEY=replace-me
S3_PUBLIC_BASE_URL=https://your-public-cdn-or-bucket-url.com

MAX_IMAGE_SIZE_MB=4
